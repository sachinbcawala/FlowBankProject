import java.util.*;

// ======================= MODEL =======================

class Customer implements Cloneable {
    private String name;
    private String email;
    private String[] phoneNumbers;

    public Customer(String name, String email, String... phoneNumbers) {
        this.name = name;
        this.email = email;
        this.phoneNumbers = phoneNumbers;
    }

    public String getName() { return name; }
    public String getEmail() { return email; }
    public String getPhoneNumber(int index) {
        if (index < 0 || index >= phoneNumbers.length) throw new IndexOutOfBoundsException();
        return phoneNumbers[index];
    }

    @Override
    public Customer clone() throws CloneNotSupportedException {
        return (Customer) super.clone();
    }

    @Override
    public String toString() {
        return "Customer{name='" + name + "', email='" + email + "'}";
    }
}

class Transaction {
    public enum Type { DEPOSIT, WITHDRAWAL, TRANSFER, INTEREST_CREDIT }

    private Type type;
    private double amount;
    private String accountId;

    public Transaction(Type type, double amount, String accountId) {
        this.type = type;
        this.amount = amount;
        this.accountId = accountId;
    }

    public String getSummary() {
        return "Transaction{" + type + ", amount=" + amount + ", accountId='" + accountId + "'}";
    }
}

// ======================= CORE =======================

abstract class Account {
    private String accountNumber;
    private Customer owner;
    private double balance;

    public Account(String accountNumber, Customer owner, double balance) {
        this.accountNumber = accountNumber;
        this.owner = owner;
        this.balance = balance;
    }

    public abstract String getAccountType();
    public abstract double calculateInterest();

    public void deposit(double amount) { balance += amount; }
    public void withdraw(double amount) {
        if (amount > balance) {
            System.out.println("Insufficient funds!");
        } else {
            balance -= amount;
        }
    }

    public double getBalance() { return balance; }
    public String getAccountNumber() { return accountNumber; }
    public Customer getOwner() { return owner; }

    @Override
    public String toString() {
        return getAccountType() + " Account{" +
                "accountNumber='" + accountNumber + '\'' +
                ", owner=" + owner +
                ", balance=" + balance +
                '}';
    }
}

class SavingsAccount extends Account {
    public SavingsAccount(String accountNumber, Customer owner, double balance) {
        super(accountNumber, owner, balance);
    }
    @Override public String getAccountType() { return "Savings"; }
    @Override public double calculateInterest() { return getBalance() * 0.04; }
}

class CurrentAccount extends Account {
    public CurrentAccount(String accountNumber, Customer owner, double balance) {
        super(accountNumber, owner, balance);
    }
    @Override public String getAccountType() { return "Current"; }
    @Override public double calculateInterest() { return 0; }
}

class FixedDepositAccount extends Account {
    public FixedDepositAccount(String accountNumber, Customer owner, double balance) {
        super(accountNumber, owner, balance);
    }
    @Override public String getAccountType() { return "Fixed Deposit"; }
    @Override public double calculateInterest() { return getBalance() * 0.07; }
}

// ======================= SERVICE =======================

interface BankService {
    void deposit(String accountId, double amount);
    void withdraw(String accountId, double amount);
    void transfer(String fromId, String toId, double amount);
    List<Transaction> getTransactionHistory(String accountId);
}

class TransactionService implements BankService {
    private Map<String, List<Transaction>> accountTransactions = new HashMap<>();

    @Override
    public void deposit(String accountId, double amount) {
        Transaction t = new Transaction(Transaction.Type.DEPOSIT, amount, accountId);
        accountTransactions.computeIfAbsent(accountId, k -> new ArrayList<>()).add(t);
        System.out.println("Deposited " + amount + " to " + accountId);
    }

    @Override
    public void withdraw(String accountId, double amount) {
        Transaction t = new Transaction(Transaction.Type.WITHDRAWAL, amount, accountId);
        accountTransactions.computeIfAbsent(accountId, k -> new ArrayList<>()).add(t);
        System.out.println("Withdrew " + amount + " from " + accountId);
    }

    @Override
    public void transfer(String fromId, String toId, double amount) {
        Transaction t = new Transaction(Transaction.Type.TRANSFER, amount, fromId + "->" + toId);
        accountTransactions.computeIfAbsent(fromId, k -> new ArrayList<>()).add(t);
        System.out.println("Transferred " + amount + " from " + fromId + " to " + toId);
    }

    @Override
    public List<Transaction> getTransactionHistory(String accountId) {
        return accountTransactions.getOrDefault(accountId, new ArrayList<>());
    }
}

// ======================= MAIN =======================

public class Main {
    public static void main(String[] args) {
        Customer c1 = new Customer("Alice", "alice@example.com", "12345", "67890");
        Account savings = new SavingsAccount("A001", c1, 1000);

        System.out.println(savings);
        savings.deposit(500);
        savings.withdraw(200);
        System.out.println("Balance: " + savings.getBalance());
        System.out.println("Interest: " + savings.calculateInterest());

        TransactionService ts = new TransactionService();
        ts.deposit("A001", 500);
        ts.withdraw("A001", 200);
        ts.transfer("A001", "A002", 300);

        System.out.println("Transaction history for A001:");
        for (Transaction t : ts.getTransactionHistory("A001")) {
            System.out.println(t.getSummary());
        }
    }
}
